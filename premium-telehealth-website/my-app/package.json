{
  "name": "my-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbo",
    "build": "next build",
    "build:analyze": "cross-env ANALYZE=true next build",
    "start": "next start",
    "lint": "NODE_OPTIONS='--max-old-space-size=4096' eslint",
    "lint:fix": "NODE_OPTIONS='--max-old-space-size=4096' eslint --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:smoke": "npx tsx scripts/smoke-test.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:perf": "npx tsx scripts/performance-test.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "npx tsx scripts/seed.ts",
    "db:validate": "prisma validate",
    "db:format": "prisma format",
    "cache:clear": "npx tsx scripts/clear-cache.ts",
    "security:audit": "npm audit && npm audit fix",
    "clean": "rm -rf .next node_modules/.cache",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "deploy": "./scripts/deploy.sh",
    "backup": "./scripts/backup.sh",
    "health-check": "./scripts/health-check.sh"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.996.0",
    "@aws-sdk/s3-request-presigner": "^3.996.0",
    "@hookform/resolvers": "^5.2.2",
    "@netlify/blobs": "^10.7.4",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@sendgrid/mail": "^8.1.6",
    "@stripe/stripe-js": "^8.8.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "bcrypt": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.34.1",
    "ioredis": "^5.9.3",
    "lucide-react": "^0.574.0",
    "next": "16.1.6",
    "otpauth": "^9.5.0",
    "pg": "^8.18.0",
    "prisma": "^7.4.1",
    "qrcode.react": "^4.2.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.1",
    "server-only": "^0.0.1",
    "stripe": "^20.3.1",
    "tailwind-merge": "^3.4.1",
    "twilio": "^5.12.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.1.6",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^20.19.33",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^4.0.18",
    "cross-env": "^7.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^28.1.0",
    "prettier": "^3.5.3",
    "shadcn": "^3.8.5",
    "supertest": "^6.3.4",
    "tailwindcss": "^4",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.19.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "browserslist": [
    ">= 0.5%",
    "last 2 major versions",
    "not dead",
    "Chrome >= 90",
    "Firefox >= 88",
    "Safari >= 14",
    "Edge >= 90"
  ]
}
