# ============================================================
# Rimal Health — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# ----------------------------
# Application
# ----------------------------
NEXT_PUBLIC_APP_URL=https://rimalhealth.com
NEXT_PUBLIC_APP_NAME="Rimal Health"
# Public site URL (used by some integrations / OG tags)
# NEXT_PUBLIC_SITE_URL=https://rimalhealth.com

# ----------------------------
# Database (PostgreSQL)
# ----------------------------
# Local Development:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rimalhealth?schema=public

# AWS RDS Production:
# DATABASE_URL=postgresql://USER:PASSWORD@rimalhealth.cluster-xxx.us-east-1.rds.amazonaws.com:5432/rimalhealth?sslmode=require

# ----------------------------
# Authentication (JWT)
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ----------------------------
# JWT_SECRET=your-super-secret-jwt-key

# ----------------------------
# PHI Encryption (AES-256-GCM, used by Prisma encryption extension)
# 32 bytes (256 bits) hex-encoded => exactly 64 hex chars.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ----------------------------
# PHI_ENCRYPTION_KEY=your-64-char-hex-key

# Hash salt for the audit log hash chain (do NOT use the default in prod).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# AUDIT_HASH_SALT=your-audit-hash-salt

# ----------------------------
# Session & CSRF
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ----------------------------
# SESSION_SECRET=your-super-secret-session-key

# ----------------------------
# Redis (Sessions, Cache, Rate Limiting)
# Local: redis://localhost:6379
# AWS ElastiCache: redis://xxx.cache.amazonaws.com:6379
# ----------------------------
# REDIS_URL=redis://localhost:6379
# REDIS_TLS_ENABLED=true
# REDIS_PASSWORD=your-redis-password

# ----------------------------
# Contact / Email
# ----------------------------
# CONTACT_FORM_TO_EMAIL=support@rimalhealth.com
# ADMIN_EMAIL=admin@admin.rimalhealth.com

# ----------------------------
# Analytics (Google Analytics 4)
# https://analytics.google.com
# ----------------------------
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ----------------------------
# Feature Flags
# ----------------------------
NEXT_PUBLIC_ENABLE_INTAKE=true
# Set to "false" to bypass payment gating in non-prod envs (default: true)
# REQUIRE_PAYMENT=true
# Set to "true" to disable Redis/in-memory API caching for debugging
# DISABLE_API_CACHE=false

# ----------------------------
# Payment (Stripe)
# https://dashboard.stripe.com/apikeys
# ----------------------------
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# Stripe Price IDs (create products in Stripe Dashboard)
# https://dashboard.stripe.com/products
# STRIPE_PRICE_ACTIVE_TREATMENT=price_xxxxxxxxxxxxxxxxxxxx   # AUD ($50/mo)
# STRIPE_PRICE_WEIGHT_MANAGEMENT=price_xxxxxxxxxxxxxxxxxxxx  # GLP-1 weight mgmt ($50/mo) — Phase 5
# STRIPE_PRICE_MAINTENANCE=price_xxxxxxxxxxxxxxxxxxxx

# Stripe Product IDs (optional, for customer portal configuration)
# STRIPE_PRODUCT_ACTIVE_TREATMENT=prod_xxxxxxxxxxxxxxxxxxxx
# STRIPE_PRODUCT_WEIGHT_MANAGEMENT=prod_xxxxxxxxxxxxxxxxxxxx  # GLP-1 weight mgmt — Phase 5
# STRIPE_PRODUCT_MAINTENANCE=prod_xxxxxxxxxxxxxxxxxxxx

# Stripe Webhook Configuration
# For local development, use Stripe CLI: stripe listen --forward-to localhost:3000/api/webhooks/stripe
# For production, configure webhook endpoint in Stripe Dashboard: https://dashboard.stripe.com/webhooks
# Required webhook events:
#   - checkout.session.completed
#   - invoice.payment_succeeded
#   - invoice.payment_failed
#   - customer.subscription.created
#   - customer.subscription.updated
#   - customer.subscription.deleted

# Test card numbers:
# Success: 4242 4242 4242 4242
# Decline: 4000 0000 0000 0002
# Insufficient funds: 4000 0000 0000 9995

# ----------------------------
# Email (Amazon SES — replaces SendGrid)
# In ECS/Amplify, the task role provides AWS credentials. Locally, use
# AWS_PROFILE or AWS_ACCESS_KEY_ID/SECRET_ACCESS_KEY (development only).
# ----------------------------
# SES_FROM_EMAIL=noreply@rimalhealth.com
# SES_FROM_NAME=Rimal Health

# ----------------------------
# SMS (Amazon SNS — replaces Twilio)
# Same credential rules as SES — no app-level secrets in production.
# ----------------------------
# (no app-level vars; AWS_REGION + IAM role drive SNS)

# ----------------------------
# File Storage
# Default: 'netlify' (Netlify Blobs, no config needed)
# Set to 's3' and configure AWS S3 bucket below for production storage.
# Credentials: ECS/Amplify task role provides them automatically.
# Do NOT set AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY in production.
# ----------------------------
STORAGE_PROVIDER=netlify

# AWS S3 (only needed when STORAGE_PROVIDER=s3)
# AWS_S3_BUCKET_NAME=rimalhealth-documents
# AWS_REGION=us-east-1

# ----------------------------
# Address Validation (Amazon Location Service)
# ----------------------------
# AWS_LOCATION_PLACE_INDEX=RimalHealthPlaceIndex

# ----------------------------
# Security & Rate Limiting
# ----------------------------
# Rate limit window in milliseconds (default: 60000 = 1 minute)
# RATE_LIMIT_WINDOW_MS=60000

# Max requests per window for authenticated users (default: 100)
# RATE_LIMIT_MAX_REQUESTS=100

# Max requests per window for unauthenticated users (default: 20)
# RATE_LIMIT_UNAUTH_MAX_REQUESTS=20

# Max login attempts per window (default: 5)
# RATE_LIMIT_LOGIN_MAX_ATTEMPTS=5

# ----------------------------
# Cron / Scheduled Jobs
# Used to authenticate cron triggers (e.g. email retry worker).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ----------------------------
# CRON_SECRET=your-cron-secret-here

# ----------------------------
# HIPAA Audit Logging
# ----------------------------
# Enable detailed audit logging (default: true)
# AUDIT_LOGGING_ENABLED=true

# Audit log retention days (default: 2555 = 7 years)
# AUDIT_LOG_RETENTION_DAYS=2555

# ----------------------------
# Data Retention Policy
# ----------------------------
# Patient data retention after account closure (days)
# DATA_RETENTION_DAYS_AFTER_CLOSURE=2555

# Soft delete grace period (days)
# SOFT_DELETE_GRACE_PERIOD_DAYS=30
